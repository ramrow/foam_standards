FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "rho.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-08;
        relTol          0.1;
    }

    p
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-06;
        relTol          0.05;
    }

    U
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-06;
        relTol          0.05;
    }

    T
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-06;
        relTol          0.05;
    }

    "alpha.*"
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-06;
        relTol          0.05;
    }
}

PIMPLE
{
    nOuterCorrectors  1;
    nCorrectors       2;
    nNonOrthogonalCorrectors  0;
    momentumPredictor yes;
    transonic         no;
    aggressive        yes;
    turbOnFinalIter   yes;
}

relaxationFactors
{
    equations
    {
        "rho.*"     0.7;
        p           0.3;
        U           0.7;
        T           0.7;
        "alpha.*"   0.7;
    }
}

