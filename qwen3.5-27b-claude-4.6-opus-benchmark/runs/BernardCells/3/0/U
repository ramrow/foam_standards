FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

// Velocity field for Bernard Cell natural convection simulation
// Domain: 9m (x) x 1m (y) x 2m (z)
// Hot wall at x=0 (310K), Cold wall at x=9 (300K)
// Solver: buoyantFoam with heRhoThermo (sensibleEnthalpy)
//
// Initial condition: fluid at rest (zero velocity)
// Buoyancy forces will develop the characteristic Bernard Cell circulation
// Warm fluid rises along hot wall, cool fluid descends along cold wall

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    hotWall
    {
        type            noSlip;
    }

    coldWall
    {
        type            noSlip;
    }

    bottom
    {
        type            noSlip;
    }

    top
    {
        type            noSlip;
    }

    front
    {
        type            noSlip;
    }

    back
    {
        type            noSlip;
    }
}