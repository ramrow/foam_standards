FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

thermoType
{
    type            hePsiThermo;
    mixture         pureMixture;
    transport       const;
    thermo          perfectGas;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        nMoles          1;
        molWeight       11640.3;
    }

    thermodynamics
    {
        Cp              2.5;
        Hf              0;
        Sf              0;
    }

    transport
    {
        mu              0;
        Pr              1.0;
    }

    equationOfState
    {
        pRef            1;
        TRef            1;
    }
}