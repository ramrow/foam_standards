FoamFile
{
    format      ascii;
    class       volScalarField;
    object      rho;
}

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 1.4;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1.4;
    }

    outlet
    {
        type            zeroGradient;
    }

    top
    {
        type            fixedValue;
        value           uniform 1.4;
    }

    bottom
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            empty;
    }
}