FoamFile
{
    format      ascii;
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

4
(
    inlet
    {
        type            patch;
        nFaces          10;
        startFace       180;
    }
    outlet
    {
        type            patch;
        nFaces          10;
        startFace       190;
    }
    walls
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          20;
        startFace       200;
    }
    defaultFaces
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          200;
        startFace       220;
    }
)

