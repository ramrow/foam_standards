FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}


application     rhoCentralFoam;

startFrom       startTime;

startTime       0.0;

stopAt          endTime;

endTime         0.2;

deltaT          0.0001;

writeControl    runTime;

writeInterval   0.02;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;