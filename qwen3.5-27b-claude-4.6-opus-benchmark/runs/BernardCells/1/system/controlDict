FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

// Application
application     buoyantFoam;

// Run control
startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         1000;

deltaT          1;

// Write control
writeControl    runTime;

writeInterval   50;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

// Execution control
runTimeRedirect no;

// Function objects (none required for basic simulation)
functions
{
}

// Additional libraries
libs
(
);