FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{	
    bottomWall
    {
        type            fixedFluxPressure;
        value           $internalField;
    }
	
	topWall
    {
        type            fixedFluxPressure;
        value           $internalField;
    }
	
	posts
    {
        type            fixedFluxPressure;
        value           $internalField;
    }
	
    inlet
    {
        type            fixedFluxPressure;
        value           $internalField;
    }
	
    outlet
    {
        type            fixedValue;
        value           $internalField;
    }
	
    frontAndBack
    {
        type            empty;
    }
}

