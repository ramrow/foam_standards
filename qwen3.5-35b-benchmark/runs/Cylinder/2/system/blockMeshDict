FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale   1;

vertices
(
    (-0.5 -0.5 0)   // 0: Bottom Left
    ( 0.5 -0.5 0)   // 1: Bottom Right
    ( 0.5  0.5 0)   // 2: Top Right
    (-0.5  0.5 0)   // 3: Top Left
    ( 0.0 -0.2 0)   // 4: Bottom of cylinder
    ( 0.0  0.2 0)   // 5: Top of cylinder
);

blocks
(
    hex (0 4 5 3) (20 40 1) simpleGrading (1 1 1)
    hex (4 1 2 5) (20 40 1) simpleGrading (1 1 1)
);

edges
(
    arc 4 5 (0 0 0)
);

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 3 5 4)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (1 2 5 4)
        );
    }
    top
    {
        type wall;
        faces
        (
            (3 2 5 4)
        );
    }
    bottom
    {
        type wall;
        faces
        (
            (0 1 4 5)
        );
    }
    cylinder
    {
        type wall;
        faces
        (
            (4 5)
        );
    }
);

mergePatchPairs
(
);

