FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

// Velocity field for 3D Bernard Cell natural convection simulation
// Solver: buoyantFoam
// Domain: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0: 301 K, Cold wall at y=1: 300 K

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    // Hot wall at y=0 (no-slip)
    hotWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    // Cold wall at y=1 (no-slip)
    coldWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    // Bottom wall at z=0 (no-slip)
    bottomWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    // Top wall at z=2 (no-slip)
    topWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    // Left wall at x=0 (no-slip)
    leftWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    // Right wall at x=9 (no-slip)
    rightWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
}