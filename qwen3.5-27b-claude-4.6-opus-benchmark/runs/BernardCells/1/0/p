FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}

// Pressure field for 3D Bernard Cell natural convection simulation
// Solver: buoyantFoam
// Domain: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0: 301 K, Cold wall at y=1: 300 K
// Note: buoyantFoam solves for p_rgh (pressure minus hydrostatic)
// This p field is the total pressure for reference and post-processing

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    // Hot wall at y=0
    hotWall
    {
        type            zeroGradient;
    }

    // Cold wall at y=1
    coldWall
    {
        type            zeroGradient;
    }

    // Bottom wall at z=0
    bottomWall
    {
        type            zeroGradient;
    }

    // Top wall at z=2
    topWall
    {
        type            zeroGradient;
    }

    // Left wall at x=0
    leftWall
    {
        type            zeroGradient;
    }

    // Right wall at x=9
    rightWall
    {
        type            zeroGradient;
    }
}