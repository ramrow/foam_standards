FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}

// Pressure field for Bernard Cell natural convection simulation
// Domain: 9m (x) x 1m (y) x 2m (z)
// Hot wall at x=0 (310K), Cold wall at x=9 (300K)
// Solver: buoyantFoam with heRhoThermo (sensibleEnthalpy)
// Equation of state: perfectGas
//
// This is the thermodynamic (absolute) pressure for compressible flow.
// Reference pressure: 101325 Pa (atmospheric)

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    hotWall
    {
        type            zeroGradient;
    }

    coldWall
    {
        type            zeroGradient;
    }

    bottom
    {
        type            zeroGradient;
    }

    top
    {
        type            zeroGradient;
    }

    front
    {
        type            zeroGradient;
    }

    back
    {
        type            zeroGradient;
    }
}