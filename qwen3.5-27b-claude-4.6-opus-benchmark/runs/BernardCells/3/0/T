FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

// Temperature field for Bernard Cell natural convection simulation
// Domain: 9m (x) x 1m (y) x 2m (z)
// Hot wall at x=0 (310K), Cold wall at x=9 (300K)
// Solver: buoyantFoam with heRhoThermo (sensibleEnthalpy)
// Note: T is a derived field from enthalpy h, but required for initialization

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 305;

boundaryField
{
    hotWall
    {
        type            fixedValue;
        value           uniform 310;
    }

    coldWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    bottom
    {
        type            zeroGradient;
    }

    top
    {
        type            zeroGradient;
    }

    front
    {
        type            zeroGradient;
    }

    back
    {
        type            zeroGradient;
    }
}