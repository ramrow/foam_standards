FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (1.1 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (1.1 0 0);
    }

    outlet
    {
        type            zeroGradient;
    }

    obstacle
    {
        type            noSlip;
    }

    defaultFaces
    {
        type            empty;
    }
}