FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    inlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.05;
        value           uniform 1;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 1;
        value           uniform 1;
    }

    innerWall
    {
        type            kqRWallFunction;
        value           uniform 1;
    }

    outerWall
    {
        type            kqRWallFunction;
        value           uniform 1;
    }

    lowerWall
    {
        type            kqRWallFunction;
        value           uniform 1;
    }

    upperWall
    {
        type            kqRWallFunction;
        value           uniform 1;
    }
}

