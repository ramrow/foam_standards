FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

momentumTransport
{
    turbulence      off;
    laminar         on;
}

phase1
{
    type            transportModel;
    transport       Newtonian;
    nu              1e-04;
    rho             1;
}

phase2
{
    type            transportModel;
    transport       Newtonian;
    nu              1e-04;
    rho             1000;
}

