4
(
    movingWall
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          400;
        startFace       760;
    }
    fixedWalls
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          400;
        startFace       1160;
    }
    empty
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          40;
        startFace       1560;
    }
    defaultFaces
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          40;
        startFace       1600;
    }
)

