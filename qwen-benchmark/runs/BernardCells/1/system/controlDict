FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     buoyantFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         1000;

deltaT          1;

writeControl    timeStep;

writeInterval   50;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeFields     true;

readFields      true;

libs
(
    "libfieldFunctionObjects.so"
);

functions
{
}

adjustTimeStep  no;

maxCo           0.5;

maxDeltaT       1;

residualControl
{
    p
    {
        tolerance   1e-4;
        relTol      0.01;
    }
    U
    {
        tolerance   1e-4;
        relTol      0.01;
    }
    T
    {
        tolerance   1e-4;
        relTol      0.01;
    }
}