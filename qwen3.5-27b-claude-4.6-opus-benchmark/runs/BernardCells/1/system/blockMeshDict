FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// Bernard Cell 3D Natural Convection Domain
// Dimensions: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0 (301 K), Cold wall at y=1 (300 K)

// Vertices defining the rectangular domain
vertices
(
    (0 0 0)      // 0: Bottom-left-front
    (9 0 0)      // 1: Bottom-right-front
    (9 1 0)      // 2: Top-right-front
    (0 1 0)      // 3: Top-left-front
    (0 0 2)      // 4: Bottom-left-back
    (9 0 2)      // 5: Bottom-right-back
    (9 1 2)      // 6: Top-right-back
    (0 1 2)      // 7: Top-left-back
);

// Hexahedral block definition
// Format: (vertex0 vertex1 vertex2 vertex3 vertex4 vertex5 vertex6 vertex7) (nx ny nz) grading
blocks
(
    hex (0 1 2 3 4 5 6 7) (90 50 40) simpleGrading (1 1 1)
);

// Edge definitions (straight edges - default)
edges
(
);

// Boundary patches
boundary
(
    // Hot wall at y=0 (301 K)
    hotWall
    {
        type            wall;
        faces
        (
            (0 4 5 1)
        );
    }

    // Cold wall at y=1 (300 K)
    coldWall
    {
        type            wall;
        faces
        (
            (3 2 6 7)
        );
    }

    // Bottom wall at z=0 (no-slip, adiabatic)
    bottomWall
    {
        type            wall;
        faces
        (
            (0 1 2 3)
        );
    }

    // Top wall at z=2 (no-slip, adiabatic)
    topWall
    {
        type            wall;
        faces
        (
            (4 7 6 5)
        );
    }

    // Left wall at x=0 (no-slip, adiabatic)
    leftWall
    {
        type            wall;
        faces
        (
            (0 3 7 4)
        );
    }

    // Right wall at x=9 (no-slip, adiabatic)
    rightWall
    {
        type            wall;
        faces
        (
            (1 5 6 2)
        );
    }
);

// No merging of patches
mergePatchPairs
(
);