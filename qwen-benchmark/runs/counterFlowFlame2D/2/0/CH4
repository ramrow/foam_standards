dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inletFuel
    {
        type            fixedValue;
        value           uniform (1 0 0);
    }

    inletAir
    {
        type            fixedValue;
        value           uniform (0 0.21 0.79);
    }

    outlet
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            empty;
    }
}

