FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}


dimensions      [1 -1 -2 0 0];

internalField   uniform 0;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    left
    {
        type            zeroGradient;
    }

    right
    {
        type            fixedValue;
        value           $internalField;
    }

    down
    {
        type            zeroGradient;
    }

    up
    {
        type            zeroGradient;
    }
}