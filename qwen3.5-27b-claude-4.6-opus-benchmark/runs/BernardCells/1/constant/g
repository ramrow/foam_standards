// Gravity vector for Bernard Cell natural convection simulation
// Domain: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0 (301 K), Cold wall at y=1 (300 K)
// Gravity acts in negative y-direction (perpendicular to heated/cooled walls)
// This creates natural convection with hot fluid rising and cold fluid sinking

dimensions  [0 1 -2 0 0 0 0];

internalField uniform (0 -9.81 0);