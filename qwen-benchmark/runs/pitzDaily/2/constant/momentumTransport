FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType RAS;

RAS
{
    RASModel kOmegaSST;
    turbulence on;
    
    // Additional settings for kOmegaSST to prevent dimensional issues
    kOmegaSSTCoeffs
    {
        alphaK1     0.85;
        alphaK2     1.0;
        alphaOmega1 0.5;
        alphaOmega2 0.856;
        beta1       0.075;
        beta2       0.0828;
        betaStar    0.09;
        gamma1      5.0/9.0;
        gamma2      0.44;
        Prt         1.0;
        sigmak      1.0;
        sigmaOmega1 0.5;
        sigmaOmega2 0.856;
    }
}

