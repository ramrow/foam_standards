FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      momentumTransport;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Laminar dam break with obstacle
// Solver: interFoam
// Domain: 1x1x1
// Density: air=1, water=1000
// Viscosity: air=1.48e-5, water=1e-6

transportModel  Newtonian;

// Kinematic viscosity (nu)
// Order matches transportProperties: (nu_air, nu_water)
// nu_air = 1.48e-05, nu_water = 1e-06
nu              (1.48e-05 1e-06);

// Density (rho)
// Order matches transportProperties: (rho_air, rho_water)
// rho_air = 1, rho_water = 1000
rho             (1 1000);

// Surface tension coefficient (sigma)
// Consistent with transportProperties
sigma           0.072;

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //