FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 2;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 2;
    }
    outlet
    {
        type            zeroGradient;
    }
    wedge
    {
        type            wedge;
    }
    walls
    {
        type            fixedValue;
        value           uniform 2;
    }
}

// ************************************************************************* //