FoamFile
{
    format      ascii;
    class       volScalarField;
    object      epsilon;
}


dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    movingWall
    {
        type            epsilonWallFunction;
        value           uniform 0.01;
    }

    fixedWalls
    {
        type            epsilonWallFunction;
        value           uniform 0.01;
    }

    frontAndBack
    {
        type            empty;
    }
}