FoamFile
{
    format      ascii;
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

6
(
    inlet
    {
        type            patch;
        nFaces          10;
        startFace       1780;
    }
    outlet
    {
        type            patch;
        nFaces          10;
        startFace       1790;
    }
    walls
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          205;
        startFace       1800;
    }
    emptyFront
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          950;
        startFace       2005;
    }
    emptyBack
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          950;
        startFace       2955;
    }
    defaultFaces
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          15;
        startFace       3905;
    }
)

