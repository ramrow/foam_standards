FoamFile
    {
        version     2.0;
        format      ascii;
        class       dictionary;
        object      transportProperties;
    }

    // * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

    rhoInf      1;
    muInf       0;

    // Normalized properties
    molWeight   11640.3;
    Cp          2.5;
    Pr          1.0;
    mu          0;

    // Derived constants for consistency
    // R = 8314.46 / molWeight = 8314.46 / 11640.3 = 0.7143
    // gamma = Cp / (Cp - R) = 2.5 / (2.5 - 0.7143) = 1.4
    R           0.7143;
    gamma       1.4;

    // * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
}