FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alphat;
}

dimensions      [1 -1 -1 0 0 0 0];

internalField   uniform 1e-4;

boundaryField
{
    hotWall
    {
        type            compressible::alphatWallFunction;
        value           uniform 1e-4;
    }

    coldWall
    {
        type            compressible::alphatWallFunction;
        value           uniform 1e-4;
    }

    frontAndBack
    {
        type            empty;
    }
}