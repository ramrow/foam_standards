FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}


dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 1e5;

boundaryField
{
    fuel
    {
        type            zeroGradient;
    }
    air
    {
        type            zeroGradient;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 1e5;
        value           uniform 1e5;
    }
}