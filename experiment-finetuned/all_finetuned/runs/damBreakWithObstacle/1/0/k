FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    leftWall
    {
        type            kqRWallFunction;
        value           uniform 0;
    }

    rightWall
    {
        type            kqRWallFunction;
        value           uniform 0;
    }

    lowerWall
    {
        type            kqRWallFunction;
        value           uniform 0;
    }

    upperWall
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }

    frontAndBack
    {
        type            empty;
    }
}

