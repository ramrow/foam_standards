FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 2;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 2;
    }

    outlet
    {
        type            waveTransmissive;
        field           T;
        psi             thermo:psi;
        gamma           1.4;
        fieldInf        2;
        lInf            1;
        value           uniform 2;
    }

    bottom
    {
        type            symmetryPlane;
    }

    top
    {
        type            waveTransmissive;
        field           T;
        psi             thermo:psi;
        gamma           1.4;
        fieldInf        2;
        lInf            1;
        value           uniform 2;
    }

    wedge
    {
        type            slip;
    }

    frontAndBack
    {
        type            empty;
    }
}

// ************************************************************************* //