FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            hePsiThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie;
    energy          sensibleEnthalpy;
}

mixture
{
    thermodynamics
    {
        Cp              2.5;
        Hf              0;
    }

    transport
    {
        mu              0;
        Pr              1.0;
    }

    specie
    {
        molWeight       11640.3;
    }
}

