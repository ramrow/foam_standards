FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Chemistry solver
chemistrySolver ode;

// Reaction mechanism file
reactionFile reactions;

// Thermodynamic data file
thermoFile thermodynamics;

// Transport properties file
transportFile transport;

// Fuel species
fuelSpecie CH4;

// Oxidizer species
oxidiserSpecie O2;

// Inert species
inertSpecie N2;

// Species list
species
(
    CH4
    O2
    N2
    CO2
    H2O
    CO
    H2
    OH
    H
    O
);

// Combustion model
combustionModel perfectGas;

// Energy source term
energySource none;

// ************************************************************************* //