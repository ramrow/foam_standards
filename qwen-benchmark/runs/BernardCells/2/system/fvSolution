FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(U|k|epsilon|omega|nuTilda)"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-08;
        relTol          0.1;
    }

    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-08;
        relTol          0.01;
    }

    "(T|Yi)"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-08;
        relTol          0.1;
    }

    pFinal
    {
        $p;
        relTol          0.01;
    }

    TFinal
    {
        $T;
        relTol          0.01;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 0;

    pRefCell        0;
    pRefValue       0;

    residualControl
    {
        "(U|k|epsilon|omega|nuTilda|T)"
        {
            tolerance       1e-08;
            relTol          0.01;
        }
    }
}

PIMPLE
{
    nOuterCorrectors 1;
    nCorrectors       1;
    nNonOrthogonalCorrectors 0;
    momentumPredictor yes;
    turbOnFinalIterOnly no;
}

relaxationFactors
{
    equations
    {
        U               0.7;
        k               0.3;
        epsilon         0.3;
        T               0.7;
        p               0.3;
    }
}

