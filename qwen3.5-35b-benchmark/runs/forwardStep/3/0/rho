FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      rho;
}

dimensions      [0 -3 0 0 0 0 0];

internalField   uniform 1.225;

boundaryField
{
    inlet
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }

    floor
    {
        type            zeroGradient;
    }

    ceiling
    {
        type            zeroGradient;
    }

    step
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            empty;
    }
}