FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

boxes
(
    box
    {
        type            box;
        box             (0 0 0) (1 1 0.1);
    }
);

fields
(
    h
    {
        defaultFieldValue   uniform 0.02;
    }
    gh
    {
        defaultFieldValue   uniform 0.0;
    }
    U
    {
        defaultFieldValue   uniform (0.001 0 0);
    }
);

