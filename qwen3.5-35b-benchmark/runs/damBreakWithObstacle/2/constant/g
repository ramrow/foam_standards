FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      transportProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phase1          water;
phase2          air;

transportModel  Newtonian;

// Water properties
nu              water 1e-3;

// Air properties
nu              air 1e-4;

// Densities (kg/m3)
rho1            water 1000;
rho2            air 1;

// Surface tension coefficient (N/m)
sigma           0.072;

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //