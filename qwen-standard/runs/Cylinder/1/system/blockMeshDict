FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

backgroundMesh
{
    xMin   -0.1;
    xMax    0.3;
    yMin   -0.05;
    yMax    0.05;
    xCells  80;
    yCells  20;
}

convertToMeters 1;

vertices
(
    ($!backgroundMesh/xMin $!backgroundMesh/yMin 0)
    ($!backgroundMesh/xMax $!backgroundMesh/yMin 0)
    ($!backgroundMesh/xMax $!backgroundMesh/yMax 0)
    ($!backgroundMesh/xMin $!backgroundMesh/yMax 0)
    ($!backgroundMesh/xMin $!backgroundMesh/yMin 1)
    ($!backgroundMesh/xMax $!backgroundMesh/yMin 1)
    ($!backgroundMesh/xMax $!backgroundMesh/yMax 1)
    ($!backgroundMesh/xMin $!backgroundMesh/yMax 1)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (10 10 1) simpleGrading (1 1 1)
);

defaultPatch
{
    type patch;
}

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 1 2 3)
        );
    }

    outlet
    {
        type patch;
        faces
        (
            (4 5 6 7)
        );
    }

    walls
    {
        type patch;
        faces
        (
            (0 3 7 4)
        );
    }

    cylinder
    {
        type patch;
        faces
        (
            (1 2 6 5)
        );
    }
);