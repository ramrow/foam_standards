FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nuTilda;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 1e-05;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 1e-05;
    }

    outlet
    {
        type            calculated;
        value           uniform 1e-05;
    }

    walls
    {
        type            nutUSpaldingWallFunction;
        value           uniform 1e-05;
    }

    frontAndBack
    {
        type            empty;
    }
}

