FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 1e-05;

boundaryField
{
    left
    {
        type            epsilonWallFunction;
        value           uniform 1e-05;
    }
    right
    {
        type            epsilonWallFunction;
        value           uniform 1e-05;
    }
    bottom
    {
        type            epsilonWallFunction;
        value           uniform 1e-05;
    }
    top
    {
        type            epsilonWallFunction;
        value           uniform 1e-05;
    }
    front
    {
        type            empty;
    }
    back
    {
        type            empty;
    }
}