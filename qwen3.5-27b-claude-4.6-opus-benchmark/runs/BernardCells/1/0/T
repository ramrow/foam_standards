FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

// Temperature field for 3D Bernard Cell natural convection simulation
// Solver: buoyantFoam
// Domain: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0: 301 K, Cold wall at y=1: 300 K

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300.5;

boundaryField
{
    // Hot wall at y=0 (301 K)
    hotWall
    {
        type            fixedValue;
        value           uniform 301;
    }

    // Cold wall at y=1 (300 K)
    coldWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    // Bottom wall at z=0 (adiabatic)
    bottomWall
    {
        type            zeroGradient;
    }

    // Top wall at z=2 (adiabatic)
    topWall
    {
        type            zeroGradient;
    }

    // Left wall at x=0 (adiabatic)
    leftWall
    {
        type            zeroGradient;
    }

    // Right wall at x=9 (adiabatic)
    rightWall
    {
        type            zeroGradient;
    }
}