FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}

// Bernard Cell 3D Simulation - Turbulent Dissipation Rate
// Solver: buoyantFoam
// Domain: 9 m (X) x 1 m (Y) x 2 m (Z)
// Hot wall at x=0 (305 K), Cold wall at x=9 (300 K)
// Turbulence model: k-epsilon (natural convection)

// ============================================================================
// INITIAL CONDITION CALCULATION
// ============================================================================
// For k-epsilon model with natural convection:
//
// Given parameters:
//   k     = 0.001 m²/s² (from k field)
//   nu    = 1.5e-5 m²/s (from transportProperties)
//   L_t   = 0.1 m (turbulent length scale ~10% of domain height)
//   C_mu  = 0.09 (standard k-epsilon constant)
//
// Calculation:
//   epsilon = C_mu^(3/4) * k^(3/2) / L_t
//   epsilon = 0.09^(3/4) * (0.001)^(3/2) / 0.1
//   epsilon = 0.177 * 3.16e-5 / 0.1
//   epsilon = 5.6e-5 m²/s³
//
// Verification via turbulent viscosity:
//   nu_t = C_mu * k² / epsilon
//   nu_t = 0.09 * (0.001)² / 5.6e-5 = 1.6e-6 m²/s
//   Re_t = nu_t / nu = 1.6e-6 / 1.5e-5 ≈ 0.1 (laminar-to-transitional)
//
// This is appropriate for Rayleigh number ~5e8 (turbulent natural convection)

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 5.6e-05;

boundaryField
{
    hotWall
    {
        type            zeroGradient;
    }

    coldWall
    {
        type            zeroGradient;
    }

    topWall
    {
        type            zeroGradient;
    }

    bottomWall
    {
        type            zeroGradient;
    }

    frontWall
    {
        type            zeroGradient;
    }

    backWall
    {
        type            zeroGradient;
    }
}