FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      g;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 9.81;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 9.81;
    }

    outlet
    {
        type            zeroGradient;
    }

    front
    {
        type            zeroGradient;
    }

    back
    {
        type            zeroGradient;
    }

    hotWall
    {
        type            fixedValue;
        value           uniform 9.81;
    }

    coldWall
    {
        type            fixedValue;
        value           uniform 9.81;
    }
}

