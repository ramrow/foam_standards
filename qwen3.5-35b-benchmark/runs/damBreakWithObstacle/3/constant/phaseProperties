FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      phaseProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

nu1 1e-4;
nu2 1e-4;

phase1
{
    phaseProperties
    {
        phaseType   incompressible;
        transportModel Newtonian;
        nu          $nu1;
        rho         $rho1;
    }
}

phase2
{
    phaseProperties
    {
        phaseType   incompressible;
        transportModel Newtonian;
        nu          $nu2;
        rho         $rho2;
    }
}

alphas
{
    phase1      alpha.water;
    phase2      alpha.air;
}

sigma       0.073;

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //