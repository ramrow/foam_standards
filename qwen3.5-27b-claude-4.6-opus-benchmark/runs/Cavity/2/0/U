FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    bottomWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    rightWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    movingWall
    {
        type            fixedValue;
        value           uniform (1.5 0 0);
    }

    leftWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    frontAndBack
    {
        type            empty;
    }
}