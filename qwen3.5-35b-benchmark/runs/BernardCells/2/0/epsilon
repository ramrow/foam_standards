FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.001;

boundaryField
{
    left
    {
        type            fixedValue;
        value           uniform 0.001;
    }

    right
    {
        type            fixedValue;
        value           uniform 0.001;
    }

    bottom
    {
        type            fixedValue;
        value           uniform 0.001;
    }

    top
    {
        type            fixedValue;
        value           uniform 0.001;
    }

    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //