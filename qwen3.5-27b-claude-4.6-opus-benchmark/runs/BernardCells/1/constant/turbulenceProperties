FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}

// Turbulence model settings for 3D Bernard Cell natural convection simulation
// Solver: buoyantFoam
// Domain: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0: 301 K, Cold wall at y=1: 300 K

simulationType RAS;

RAS
{
    RASModel        kEpsilon;
    turbulence      on;
    printCoeffs     on;
}