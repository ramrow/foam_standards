FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Reaction mechanism file
chemistryFile   "chemistryFile";

// Species list
species
(
    CH4
    O2
    N2
);

// Fuel composition
fuel
{
    CH4 1.0;
};

// Oxidizer composition
oxidiser
{
    O2 1.0;
    N2 3.76;
};

// Inlet velocities
fuelInletVelocity   0.2;

airInletVelocity    -0.1;

// Chemistry solver settings
chemistrySolver     CHEMKIN;

// Enable chemistry
chemistry           yes;

// ************************************************************************* //