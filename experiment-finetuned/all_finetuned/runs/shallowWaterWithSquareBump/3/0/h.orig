FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      h;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform 0.03;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.03;
    }

    outlet
    {
        type            fixedValue;
        value           uniform 0.03;
    }

    sides
    {
        type            fixedValue;
        value           uniform 0.03;
    }

    top
    {
        type            empty;
    }

    bottom
    {
        type            empty;
    }
}

// ************************************************************************* //