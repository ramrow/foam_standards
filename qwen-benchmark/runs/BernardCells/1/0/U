FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 1 -1 0 0 0 0 ];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    outlet
    {
        type            zeroGradient;
    }

    front
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    back
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    hotWall
    {
        type            noSlip;
    }

    coldWall
    {
        type            noSlip;
    }
}

