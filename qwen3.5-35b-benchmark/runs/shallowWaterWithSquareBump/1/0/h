FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0.001 0 0);

boundaryField
{
    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }

    top
    {
        type            slip;
    }

    bottom
    {
        type            noSlip;
    }

    left
    {
        type            patch;
        value           uniform (0.001 0 0);
    }

    right
    {
        type            patch;
        value           uniform (0.001 0 0);
    }
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //