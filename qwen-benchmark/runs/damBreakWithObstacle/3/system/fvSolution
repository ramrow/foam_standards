FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-06;
        relTol          0.01;
    }

    pFinal
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-06;
        relTol          0.01;
    }

    U
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-08;
        relTol          0.1;
    }

    T
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-08;
        relTol          0.1;
    }

    phi
    {
        solver          GaussLinear;
        tolerance       1e-08;
        relTol          0.01;
    }
}

PIMPLE
{
    nOuterCorrectors  1;
    nCorrectors       2;
    nNonOrthogonalCorrectors  0;
    momentumPredictor  true;
    turbOnFinalIterOnly  false;
}

relaxationFactors
{
    equations
    {
        U   0.7;
        p   0.3;
        phi 0.5;
    }
}

