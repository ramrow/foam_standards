// Gravity vector for Bernard Cell natural convection simulation
// Domain: 9m (x) x 1m (y) x 2m (z)
// Hot wall at x=0 (310K), Cold wall at x=9 (300K)
//
// Gravity points downward (-z direction) so that buoyancy force
// drives warm fluid upward along the hot wall, creating the
// characteristic Bernard Cell circulation pattern.

dimensions  [0 1 -2 0 0 0 0];

value       (0 0 -9.81);