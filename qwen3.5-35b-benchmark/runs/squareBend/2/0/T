dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 110000;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 110000;
    }

    outlet
    {
        type            fixedValue;
        value           uniform 110000;
    }

    walls
    {
        type            zeroGradient;
    }
}

