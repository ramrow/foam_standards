FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}

// Bernard Cell 3D Simulation - Static Pressure Field
// Solver: buoyantFoam
// Domain: 9 m (X) x 1 m (Y) x 2 m (Z)
// Hot wall at x=0 (305 K), Cold wall at x=9 (300 K)

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;            // Atmospheric pressure (Pa)

boundaryField
{
    hotWall
    {
        type            zeroGradient;
    }

    coldWall
    {
        type            zeroGradient;
    }

    topWall
    {
        type            zeroGradient;
    }

    bottomWall
    {
        type            zeroGradient;
    }

    frontWall
    {
        type            zeroGradient;
    }

    backWall
    {
        type            zeroGradient;
    }
}
