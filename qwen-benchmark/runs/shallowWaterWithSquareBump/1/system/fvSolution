FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "h.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-08;
        relTol          0.1;
    }

    "U.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-08;
        relTol          0.1;
    }
}

PIMPLE
{
    nOuterCorrectors  1;
    nCorrectors       1;
    nNonOrthogonalCorrectors 0;
    momentumPredictor true;
    turbOnFinalIterOnly false;
}

relaxationFactors
{
    equations
    {
        h
        {
            factor 0.3;
        }
        U
        {
            factor 0.3;
        }
    }
}

// ************************************************************************* //