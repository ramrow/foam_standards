FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

// Turbulent kinetic energy field for 3D Bernard Cell natural convection simulation
// Solver: buoyantFoam
// Domain: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0: 301 K, Cold wall at y=1: 300 K
// Turbulence model: k-epsilon (RAS)

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1e-06;

boundaryField
{
    // Hot wall at y=0
    hotWall
    {
        type            kqRWallFunction;
        q               0;
        value           uniform 1e-06;
    }

    // Cold wall at y=1
    coldWall
    {
        type            kqRWallFunction;
        q               0;
        value           uniform 1e-06;
    }

    // Bottom wall at z=0
    bottomWall
    {
        type            kqRWallFunction;
        q               0;
        value           uniform 1e-06;
    }

    // Top wall at z=2
    topWall
    {
        type            kqRWallFunction;
        q               0;
        value           uniform 1e-06;
    }

    // Left wall at x=0
    leftWall
    {
        type            kqRWallFunction;
        q               0;
        value           uniform 1e-06;
    }

    // Right wall at x=9
    rightWall
    {
        type            kqRWallFunction;
        q               0;
        value           uniform 1e-06;
    }
}