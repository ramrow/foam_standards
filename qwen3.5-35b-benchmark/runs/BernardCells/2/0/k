FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 302.5;

boundaryField
{
    left
    {
        type            fixedValue;
        value           uniform 305;
    }

    right
    {
        type            fixedValue;
        value           uniform 300;
    }

    bottom
    {
        type            zeroGradient;
    }

    top
    {
        type            zeroGradient;
    }

    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }
}

