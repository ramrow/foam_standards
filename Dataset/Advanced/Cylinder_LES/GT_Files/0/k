FoamFile
{
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    left
    {
        type            fixedValue;
        value           uniform 2e-05;
    }

    right
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }

    up
    {
        type            fixedValue;
        value           uniform 0;
    }

    down
    {
        type            fixedValue;
        value           uniform 0;
    }
    
    cylinder
    {
        type            fixedValue;
        value           uniform 0;
    }

    defaultFaces
    {
        type            empty;
    }
}

