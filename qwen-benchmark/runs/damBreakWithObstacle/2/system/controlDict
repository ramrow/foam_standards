FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     interFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.1;

deltaT          0.001;

writeControl    timeStep;

writeInterval   20;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeFields     true;

readFields      true;

libs
(
    "libOpenFOAM.so"
    "libfiniteVolume.so"
    "libincompressibleTransportModels.so"
    "libinterFoam.so"
);

functions
{
    // No post-processing functions needed
}

