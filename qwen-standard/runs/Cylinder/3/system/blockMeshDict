FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}


backgroundMesh
{
    xMin   -0.1;
    xMax    0.3;
    yMin   -0.1;
    yMax    0.1;
    xCells  80;
    yCells  40;
}

convertToMeters 1;

vertices
(
    ($!backgroundMesh/xMin $!backgroundMesh/yMin 0)
    ($!backgroundMesh/xMax $!backgroundMesh/yMin 0)
    ($!backgroundMesh/xMax $!backgroundMesh/yMax 0)
    ($!backgroundMesh/xMin $!backgroundMesh/yMax 0)
    ($!backgroundMesh/xMin $!backgroundMesh/yMin 1)
    ($!backgroundMesh/xMax $!backgroundMesh/yMin 1)
    ($!backgroundMesh/xMax $!backgroundMesh/yMax 1)
    ($!backgroundMesh/xMin $!backgroundMesh/yMax 1)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (80 40 1) simpleGrading (1 1 1)
);

defaultPatch
{
    type empty;
}

boundary
(
    left
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }

    right
    {
        type patch;
        faces
        (
            (2 6 5 1)
        );
    }

    down
    {
        type wall;
        faces
        (
            (0 3 2 1)
        );
    }

    up
    {
        type wall;
        faces
        (
            (4 5 6 7)
        );
    }
);