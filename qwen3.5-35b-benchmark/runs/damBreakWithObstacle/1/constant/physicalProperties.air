FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      physicalProperties.air;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Air properties
rho_air       1;
nu_air        1.48e-05;

// Surface tension coefficient (sigma) - consistent with transportProperties
sigma         0.072;

