FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    h
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.01;
    }

    hFinal
    {
        $h;
        relTol          0;
    }

    hU
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0.01;
    }

    hUFinal
    {
        $hU;
        relTol          0;
    }
}

PIMPLE
{
    nOuterCorrectors   1;
    nCorrectors        2;
    nNonOrthogonalCorrectors 0;

    residualControl
    {
        h       1e-06;
        hU      1e-06;
    }
}

// ************************************************************************* //