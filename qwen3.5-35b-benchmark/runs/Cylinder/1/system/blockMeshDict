FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale   1;

vertices
(
    (0 -5 0)
    (20 -5 0)
    (20 5 0)
    (0 5 0)
    (0 -5 0.01)
    (20 -5 0.01)
    (20 5 0.01)
    (0 5 0.01)
);

// Geometry definition: Channel (Cylinder hole requires snappyHexMesh or multi-block)
// Domain: x=[0, 20], y=[-5, 5], z=[0, 0.01] (2D extrusion)

blocks
(
    hex (0 1 2 3 4 5 6 7) (20 20 1) simpleGrading (1 1 1)
);

edges
(
);

// Boundary patches
boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (1 2 6 5)
        );
    }
    topWall
    {
        type wall;
        faces
        (
            (0 1 5 4)
        );
    }
    bottomWall
    {
        type wall;
        faces
        (
            (3 7 6 2)
        );
    }
    frontAndBack
    {
        type empty;
        faces
        (
            (0 1 2 3)
            (4 5 6 7)
        );
    }
);

mergePatchPairs
(
);

