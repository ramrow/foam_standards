FoamFile
{
    format      ascii;
    class       volScalarField;
    object      epsilon;
}


dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    frontAndBack
    {
        type            epsilonWallFunction;
        value           uniform 1;
    }

    inlet
    {
        type            fixedValue;
        value           uniform 1;
    }

    outlet
    {
        type            zeroGradient;
    }

    walls
    {
        type            epsilonWallFunction;
        value           uniform 1;
    }
}