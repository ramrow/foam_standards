FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}

// Algorithm selection
PIMPLE
{
    nOuterCorrectors      1;
    nCorrectors           2;
    nNonOrthogonalCorrectors 0;
    consistent            yes;
    momentumPredictor     yes;
    turbulence            yes;
}

// Residual control
residualControl
{
    p               1e-5;
    U               1e-5;
    T               1e-5;
    "(k|omega|epsilon|nut)" 1e-4;
}

// Equation solvers
solvers
{
    // Pressure solver
    p
    {
        solver          GAMG;
        tolerance       1e-6;
        relTol          0.1;
        smoother        GaussSeidel;
    }
    
    // Velocity solver
    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-5;
        relTol          0.1;
    }
    
    // Temperature solver
    T
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-5;
        relTol          0.1;
    }
    
    // Flux solver
    phi
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-5;
        relTol          0.1;
    }
}

// Relaxation factors
relaxationFactors
{
    fields
    {
        p               0.3;
    }
    equations
    {
        U               0.7;
        T               0.7;
    }
}