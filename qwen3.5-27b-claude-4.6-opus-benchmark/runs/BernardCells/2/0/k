FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

// Bernard Cell 3D Simulation - Turbulent Kinetic Energy
// Solver: buoyantFoam
// Domain: 9 m (X) x 1 m (Y) x 2 m (Z)
// Hot wall at x=0 (305 K), Cold wall at x=9 (300 K)
// Turbulence model: k-epsilon (natural convection)

// Initial condition: Low turbulence level appropriate for natural convection
// Rayleigh number ~5e8 indicates turbulent natural convection
// k = 0.001 m²/s² (moderate turbulence for buoyancy-driven flow)
// This allows turbulence to develop naturally from buoyancy forces

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.001;

boundaryField
{
    hotWall
    {
        type            zeroGradient;
    }

    coldWall
    {
        type            zeroGradient;
    }

    topWall
    {
        type            zeroGradient;
    }

    bottomWall
    {
        type            zeroGradient;
    }

    frontWall
    {
        type            zeroGradient;
    }

    backWall
    {
        type            zeroGradient;
    }
}