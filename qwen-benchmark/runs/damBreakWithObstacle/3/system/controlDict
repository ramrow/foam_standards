FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     interFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.1;

deltaT          0.001;

writeControl    timeStep;

writeInterval   20;

purgeWrite      0;

timePrecision   6;

functions       {};

libs
(
    "libOpenFOAM.so"
    "libfiniteVolume.so"
    "libfvOptions.so"
);

