FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}


dimensions      [0 1 -1 0 0];

internalField   uniform (1.5 0 0);

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    left
    {
        type            fixedValue;
        value           $internalField;
    }

    right
    {
        type            zeroGradient;
    }

    down
    {
        type            noSlip;
    }

    up
    {
        type            noSlip;
    }
}