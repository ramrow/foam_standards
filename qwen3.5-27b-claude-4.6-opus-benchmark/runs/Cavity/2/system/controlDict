FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

// Application
application     pisoFoam;

// Start from
startFrom       startTime;

// Start time
startTime       0;

// Stop at
stopAt          endTime;

// End time
endTime         10;

// Write interval (every 100 time steps = 100 * 0.005 = 0.5 s)
writeInterval   0.5;

// Purge write
purgeWrite      0;

// Write format
writeFormat     ascii;

// Write precision
writePrecision  6;

// Write compression
writeCompression off;

// Time format
timeFormat      general;

// Time precision
timePrecision   6;

// Run time modifiable
runTimeModifiable yes;

// Time scheme
timeScheme      Euler;

// Courant number limit (not used with fixed deltaT but kept for consistency)
maxCo           1;

// Maximum time step (not used with fixed deltaT)
maxDeltaT       0.005;

// Fixed time step
deltaT          0.005;

// PISO algorithm settings
PISO
{
    nOuterCorrectors  1;
    nCorrectors       2;
    nNonOrthogonalCorrectors 0;
    pRefCell          0;
    pRefValue         0;
}

// Function objects (none for post-processing as requested)
functions
{
};