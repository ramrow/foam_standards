FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      hU;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -2 0 0 0 0];

internalField   uniform (0.001 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0.001 0 0);
    }

    outlet
    {
        type            fixedValue;
        value           uniform (0.001 0 0);
    }

    sides
    {
        type            fixedValue;
        value           uniform (0.001 0 0);
    }

    top
    {
        type            empty;
    }

    bottom
    {
        type            empty;
    }
}

// ************************************************************************* //