FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      h;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform 0.02;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.02;
    }
    outlet
    {
        type            fixedValue;
        value           uniform 0.02;
    }
    sides
    {
        type            fixedValue;
        value           uniform 0.02;
    }
    top
    {
        type            empty;
    }
    bottom
    {
        type            empty;
    }
}


