FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

// Application: reactingFoam for compressible combustion simulation
application     reactingFoam;

// Start from beginning
startFrom       startTime;

// Simulation start time (s)
startTime       0;

// Stop at end time
stopAt          endTime;

// Simulation end time (s)
endTime         0.5;

// Time step (s) - small value required for chemical kinetics stability
deltaT          1e-6;

// Write control based on time steps
writeControl    timeStep;

// Write every 0.05 seconds (50000 time steps)
writeInterval   50000;

// Keep all time directories
purgeWrite      0;

// Write format
writeFormat     ascii;

// Write precision
writePrecision  8;

// No compression for compatibility
writeCompression off;

// Do not print object names
printObjectNames off;

// Allow run-time modification
runTimeModifiable on;

// Time step control for adaptive stepping
adjustTimeStep  on;

// Maximum time step (s)
maxDeltaT       1e-6;

// Courant number limit for stability
maxCo           0.5;

// Maximum chemical time step ratio
maxAlphaCo      0.5;