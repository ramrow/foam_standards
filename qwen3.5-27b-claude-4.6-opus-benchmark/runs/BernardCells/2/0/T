FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

// Bernard Cell 3D Simulation - Temperature Field
// Solver: buoyantFoam
// Domain: 9 m (X) x 1 m (Y) x 2 m (Z)
// Hot wall at x=0 (305 K), Cold wall at x=9 (300 K)

// Initial condition: linear temperature profile between hot and cold walls
// T(x) = 305 - 5*(x/9) K
// This provides a physically realistic initial state for the simulation

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 302.5;

boundaryField
{
    hotWall
    {
        type            fixedValue;
        value           uniform 305;
    }

    coldWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    topWall
    {
        type            zeroGradient;
    }

    bottomWall
    {
        type            zeroGradient;
    }

    frontWall
    {
        type            zeroGradient;
    }

    backWall
    {
        type            zeroGradient;
    }
}