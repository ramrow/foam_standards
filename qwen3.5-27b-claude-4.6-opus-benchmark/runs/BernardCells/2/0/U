FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

// Bernard Cell 3D Simulation - Velocity Field
// Solver: buoyantFoam
// Domain: 9 m (X) x 1 m (Y) x 2 m (Z)
// Hot wall at x=0 (305 K), Cold wall at x=9 (300 K)

// Initial condition: zero velocity (simulation starts from rest)
// The buoyancy forces will naturally develop the convection cells

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    hotWall
    {
        type            noSlip;
    }

    coldWall
    {
        type            noSlip;
    }

    topWall
    {
        type            noSlip;
    }

    bottomWall
    {
        type            noSlip;
    }

    frontWall
    {
        type            noSlip;
    }

    backWall
    {
        type            noSlip;
    }
}