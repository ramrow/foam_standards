FoamFile
{
    format      ascii;
    class       volScalarField;
    object      omega;
}


dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    inlet
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.005;
        value           uniform 1;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 1;
        value           uniform 1;
    }

    wall
    {
        type            omegaWallFunction;
        value           uniform 1;
    }
}