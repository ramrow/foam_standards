FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue rho 1.0
    volScalarFieldValue T 1000.0
    volScalarFieldValue p 110000.0
    volVectorFieldValue U (0 0 0)
    volScalarFieldValue k 0.1
    volScalarFieldValue epsilon 0.01
);

fields
(
    volScalarFieldValue rho
    (
        box (-100 -100 -100) (100 100 100)
        1.0
    )

    volScalarFieldValue T
    (
        box (-100 -100 -100) (100 100 100)
        1000.0
    )

    volScalarFieldValue p
    (
        box (-100 -100 -100) (100 100 100)
        110000.0
    )

    volVectorFieldValue U
    (
        patch inlet
        massFlowInletVelocity
        massFlowRate constant 0.5
    )

    volVectorFieldValue U
    (
        patch outlet
        inletOutlet
        inletValue uniform (0 0 0)
        value uniform (0 0 0)
    )

    volScalarFieldValue k
    (
        box (-100 -100 -100) (100 100 100)
        0.1
    )

    volScalarFieldValue epsilon
    (
        box (-100 -100 -100) (100 100 100)
        0.01
    )
);

