FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

// Thermophysical properties for 3D Bernard Cell natural convection simulation
// Solver: buoyantFoam
// Fluid: Air at approximately 300 K and 1 atm
// Domain: 9 m (x) x 1 m (y) x 2 m (z)
// Hot wall at y=0: 301 K, Cold wall at y=1: 300 K

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       28.97;
    }
    thermodynamics
    {
        Hf              0;
        Cp              1005;
    }
    transport
    {
        mu              1.84e-05;
        Pr              0.71;
    }
}

radiation
{
    model           none;
}