FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      physicalProperties.air;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phaseName   air;
type        incompressible;
transportModel  Newtonian;

nu          nu[air];
rho         rho[air];

