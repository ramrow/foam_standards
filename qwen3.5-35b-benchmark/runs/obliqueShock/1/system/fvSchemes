FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
    grad(p)         Gauss linear;
    grad(U)         Gauss linear;
    grad(T)         Gauss linear;
}

divSchemes
{
    default         none;
    div(phi,U)      bounded Gauss linearUpwind grad(U);
    div(phi,T)      bounded Gauss linearUpwind grad(T);
    div(phi,e)      bounded Gauss linearUpwind grad(e);
    div(phi,k)      bounded Gauss linearUpwind grad(k);
    div(phi,omega)  bounded Gauss linearUpwind grad(omega);
    div(phi,h)      bounded Gauss linearUpwind grad(h);
    div(phi,R)      bounded Gauss linearUpwind grad(R);
    div(phi,epsilon) bounded Gauss linearUpwind grad(epsilon);
    div(phi,nuTilda) bounded Gauss linearUpwind grad(nuTilda);
    div(phi,psi)    bounded Gauss linearUpwind grad(psi);
    div(phi,nuEff)  bounded Gauss linearUpwind grad(nuEff);
    div(phi,mut)    bounded Gauss linearUpwind grad(mut);
    div(phi,phi)    none;
    div(phi,rho)    bounded Gauss linearUpwind grad(rho);
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method          meshWave;
}