FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

rhoInf          1.0;
rho0            1.0;
p0              101325;
T0              300;

transport
{
    model           const;
    nu              1.5e-5;
}

thermo
{
    model           hConst;
    Cp              1000;
    Hf              0;
    thermoType      hConst;
}

equationOfState
{
    model           perfectGas;
}

specie
{
    nMoles          1;
    molWeight       28.96;
}

energy
{
    model           sensibleEnthalpy;
    thermoType      hConst;
}

