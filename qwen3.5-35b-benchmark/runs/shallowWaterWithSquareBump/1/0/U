FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      h;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }

    top
    {
        type            patch;
        value           uniform 0.01;
    }

    bottom
    {
        type            wall;
        value           uniform 0.01;
    }

    left
    {
        type            patch;
        value           uniform 0.01;
    }

    right
    {
        type            patch;
        value           uniform 0.01;
    }
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //