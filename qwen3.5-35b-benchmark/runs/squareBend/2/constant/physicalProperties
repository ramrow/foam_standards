FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        nMoles          1;
        M               0.02897;
        W               0;
    }

    thermodynamics
    {
        Cp              1005;
        Hf              0;
    }

    transport
    {
        mu              2e-5;
        Pr              0.71;
    }

    equationOfState
    {
        p0              101325;
        T0              293;
        rho0            1.225;
    }
}

