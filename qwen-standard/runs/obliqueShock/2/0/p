FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}


dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 1.0;

boundaryField
{
    top
    {
        type            zeroGradient;
    }
    inlet
    {
        type            fixedValue;
        value           uniform 1.0;
    }
    outlet
    {
        type            zeroGradient;
    }
    bottom
    {
        type            zeroGradient;
    }
    frontAndBack
    {
        type            empty;
    }
}