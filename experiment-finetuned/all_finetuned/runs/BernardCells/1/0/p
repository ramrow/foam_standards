FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 100000;

boundaryField
{
    topWall
    {
        type            calculated;
        value           $internalField;
    }

    bottomWall
    {
        type            calculated;
        value           $internalField;
    }

    leftWall
    {
        type            calculated;
        value           $internalField;
    }

    rightWall
    {
        type            calculated;
        value           $internalField;
    }

    frontWall
    {
        type            calculated;
        value           $internalField;
    }

    backWall
    {
        type            calculated;
        value           $internalField;
    }
}

