FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale   1;

// Vertices definition
// x: -0.15242 to 0.3048
// y: 0 to 0.1524
// z: -0.005 to 0.005
// Wedge geometry: A simple wedge can be approximated by a rectangular block for a 2D slice
// assuming the wedge is the bottom boundary or an internal feature. 
// For a standard supersonic wedge simulation in a channel, we define a rectangular domain
// and apply boundary conditions to represent the wedge surface.
// However, to strictly follow "over a wedge", we usually model the wedge as a block or 
// define the bottom wall as the wedge surface. 
// Given the z-thickness is small (0.01m), we treat this as a 2D case extruded in z.
// Let's define a simple rectangular block. The wedge surface will be the bottom wall (y=0).
// If a specific wedge angle is needed, the mesh would need to be skewed, but without an angle,
// a flat plate/wedge approximation at y=0 is the standard baseline. 
// We will define a block from (-0.15242, 0, -0.005) to (0.3048, 0.1524, 0.005).

vertices
(
    (-0.15242 0 -0.005)    // 0
    ( 0.3048  0 -0.005)    // 1
    ( 0.3048  0.1524 -0.005) // 2
    (-0.15242 0.1524 -0.005) // 3
    (-0.15242 0  0.005)    // 4
    ( 0.3048  0  0.005)    // 5
    ( 0.3048  0.1524 0.005) // 6
    (-0.15242 0.1524 0.005) // 7
);

// Blocks definition
// 1 block, 200x20x2 cells (adjustable for resolution)
blocks
(
    hex (0 1 2 3 4 5 6 7) (200 20 2) simpleGrading (1 1 1)
);

// Edges (none needed for simple block)
edges
(
);

// Boundary patches
// Inlet: x = -0.15242
// Outlet: x = 0.3048
// Top: y = 0.1524
// Bottom (Wedge): y = 0
// Front/Back: z = -0.005 / 0.005 (Symmetry for 2D)
boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 3 7 4)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (1 5 6 2)
        );
    }
    top
    {
        type patch;
        faces
        (
            (3 2 6 7)
        );
    }
    wedge
    {
        type patch;
        faces
        (
            (0 1 5 4)
        );
    }
    frontAndBack
    {
        type empty;
        faces
        (
            (0 1 2 3)
            (4 5 6 7)
        );
    }
);

// Mesh generation
mergeTolerance 1e-6;