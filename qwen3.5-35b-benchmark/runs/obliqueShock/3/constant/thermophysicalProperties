FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            hePsiThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       11640.3;
    }

    thermodynamics
    {
        Cp              2.5;
        Hf              0;
    }

    transport
    {
        mu              0;
        Pr              1;
    }

    equationOfState
    {
        rho             1;
        p               1;
        T               1;
        R               0.7143;
    }
}

