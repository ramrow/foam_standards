FoamFile
{
    format      ascii;
    class       volScalarField;
    object      k;
}


dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    walls
    {
        type            kqRWallFunction;
        value           uniform 1;
    }

    inlet
    {
        type            fixedValue;
        value           uniform 1;
    }

    outlet
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            zeroGradient;
    }
}