FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      epsilon;
}


dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 20;

boundaryField
{
    inlet
    {
        type            turbulentMixingLengthDissipationRateInlet;
        mixingLength    0.005;
        value           uniform 20;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 20;
        value           uniform 20;
    }

    defaultFaces
    {
        type            empty;
    }
}