FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-06;
        relTol          0.1;
        smoother        GaussSeidel;
    }

    "(U|k|omega|nut)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-05;
        relTol          0.1;
    }
}

PIMPLE
{
    nOuterCorrectors     2;
    nInnerCorrectors     2;
    nCorrectors          2;
    nNonOrthogonalCorrectors 0;
    consistent           yes;
    pRefCell             0;
    pRefValue            0;
    residualControl
    {
        "(U|k|omega|nut)" 1e-3;
        p                    1e-4;
    }
}

relaxationFactors
{
    equations
    {
        U               0.7;
        "(k|omega|nut)" 0.7;
    }
    fields
    {
        p               0.3;
    }
}